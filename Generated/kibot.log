# Gerber and drill files for FusionPCB, without stencil
# URL: https://www.seeedstudio.io/fusion.html
# Based on setting used by Gerber Zipper (https://github.com/g200kg/kicad-gerberzipper)
kibot:
  version: 1

groups:
  - name: _FusionPCB
    outputs:
      - _FusionPCB_gerbers
      - _FusionPCB_drill

outputs:
  - name: _FusionPCB_gerbers
    comment: Gerbers compatible with FusionPCB
    type: gerber
    dir: Manufacturers/FusionPCB
    options: &gerber_options
      exclude_edge_layer: true
      exclude_pads_from_silkscreen: true
      plot_sheet_reference: false
      plot_footprint_refs: true
      plot_footprint_values: true
      force_plot_invisible_refs_vals: false
      tent_vias: true
      use_protel_extensions: true
      create_gerber_job_file: false
      output: "%f.%x"
      gerber_precision: 4.6
      use_gerber_x2_attributes: false
      use_gerber_net_attributes: false
      disable_aperture_macros: true
      line_width: 0.1
      uppercase_extensions: true
      subtract_mask_from_silk: false
      use_aux_axis_as_origin: true
      inner_extension_pattern: '.gl%N'
      edge_cut_extension: '.gml'
    layers:
      - layer: 'F.Cu'
        suffix: 'F_Cu'
        description: 'Front copper'
      - layer: 'F.Mask'
        suffix: 'F_Mask'
        description: 'Front soldermask (negative)'
      - layer: 'B.Cu'
        suffix: 'B_Cu'
        description: 'Bottom copper'
      - layer: 'B.Mask'
        suffix: 'B_Mask'
        description: 'Bottom soldermask (negative)'
      - layer: 'F.Silkscreen'
        suffix: 'F_Silkscreen'
        description: 'Front silkscreen (artwork)'
      - layer: 'B.Silkscreen'
        suffix: 'B_Silkscreen'
        description: 'Bottom silkscreen (artwork)'
      - layer: 'F.Paste'
        suffix: 'F_Paste'
        description: 'Front solder paste'
      - layer: 'B.Paste'
        suffix: 'B_Paste'
        description: 'Bottom solder paste'
      - layer: 'Edge.Cuts'
        suffix: 'Edge_Cuts'
        description: 'Board shape'
      
      

  - name: _FusionPCB_drill
    comment: Drill files compatible with FusionPCB
    type: excellon
    dir: Manufacturers/FusionPCB
    options:
      pth_and_npth_single_file: true
      use_aux_axis_as_origin: true
      output: "%f.TXT"

  - name: _FusionPCB_compress
    comment: ZIP file for FusionPCB
    type: compress
    dir: Manufacturers
    options:
      move_files: true
      files:
        - from_output: _FusionPCB_gerbers
          dest: /
        - from_output: _FusionPCB_drill
          dest: /

